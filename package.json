{
  "name": "curator",
  "displayName": "Curator",
  "description": "Fast, readable side-by-side diffs for AI-generated code changes.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "curator-sidebar",
          "title": "Curator",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "curator-sidebar": [
        {
          "id": "curator.changedFiles",
          "name": "Tree"
        }
      ]
    },
    "commands": [
      {
        "command": "curator.switchToRemote",
        "title": "Switch to Remote Mode",
        "icon": "$(cloud)",
        "category": "Curator"
      },
      {
        "command": "curator.switchToLocal",
        "title": "Switch to Local Mode",
        "icon": "$(git-commit)",
        "category": "Curator"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "curator.switchToRemote",
          "when": "view == curator.changedFiles && curator.mode == 'local'",
          "group": "navigation"
        },
        {
          "command": "curator.switchToLocal",
          "when": "view == curator.changedFiles && curator.mode == 'remote'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.80.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  }
}
